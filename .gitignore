# ── Secrets — NEVER commit ────────────────────────────────
.env
.env.*

# ── Python virtual environment ────────────────────────────
ai_mining/
.venv/
venv/
env/

# ── Python bytecode / caches ──────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── Generated output ──────────────────────────────────────
# Weekly HTML digests are regenerated each run — not source.
digests/

# ── OS / editor cruft ─────────────────────────────────────
.DS_Store
Thumbs.db
.idea/

# ── Local-only documentation (kept off the public repo) ──────
# Word/PDF docs live in "ReadMe & Summary/" locally. Ignored by file
# type because that folder name's spaces/& make a path pattern unreliable.
*.docx
*.pdf

# ── Real (private) taxonomy — keep actual search config OFF the repo ──
# Only the *.example.yaml templates are committed (generic placeholders).
# Copy them to these names and put your real topics / assignees / CPC
# codes there locally — treated like .env, never pushed.
taxonomy.yaml
patent_taxonomy.yaml

# ── NOTE on deduplication state ───────────────────────────
# seen_dois.txt and seen_patents.txt are INTENTIONALLY NOT ignored.
# They are tracked so the dedup history is preserved and so the
# "commit-back" persistence option (GAP 1) can update them on each
# GitHub Actions run. If you later switch to the actions/cache
# approach instead, add them here.
